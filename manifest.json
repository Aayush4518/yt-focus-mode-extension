{
  "manifest_version": 3,
  "name": "YouTube Focus Mode",
  "version": "1.0.0",
  "description": "A minimal extension to help you focus on YouTube videos",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://www.youtube.com/"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
